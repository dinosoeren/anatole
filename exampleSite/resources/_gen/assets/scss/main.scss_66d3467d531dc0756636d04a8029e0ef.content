}
.theme--dark .post__footer + .share-buttons a[data-color-index="2"]:hover {
  background-color: #7a4c58;
}
.theme--dark .post__footer + .share-buttons a[data-color-index="3"] {
  background-color: rgba(61, 102, 86, 0.6);
  box-shadow: unset;
  text-shadow: unset;
}
.theme--dark .post__footer + .share-buttons a[data-color-index="3"]:hover {
  background-color: #3d6656;
}
.theme--dark .post__footer + .share-buttons a[data-color-index="4"] {
  background-color: rgba(122, 98, 64, 0.6);
  box-shadow: unset;
  text-shadow: unset;
}
.theme--dark .post__footer + .share-buttons a[data-color-index="4"]:hover {
  background-color: #7a6240;
}
.theme--dark .post__footer + .share-buttons a[data-color-index="5"] {
  background-color: rgba(90, 76, 122, 0.6);
  box-shadow: unset;
  text-shadow: unset;
}
.theme--dark .post__footer + .share-buttons a[data-color-index="5"]:hover {
  background-color: #5a4c7a;
}

.notifs-overlay {
  position: fixed;
  bottom: 10px;
  right: 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.notifs-overlay .copy-notification {
  position: relative;
  right: -50px;
  opacity: 0;
  border-radius: 4px;
  color: #eeeeee;
  background-color: rgba(70, 70, 70, 0.7);
  backdrop-filter: blur(5px);
  padding: 8px;
  min-width: max-content;
  max-width: calc(50svw - 50px);
  transition: 300ms cubic-bezier(0.68, -0.55, 0.265, 1.55);
}
.notifs-overlay .copy-notification.visible {
  right: 10px;
  opacity: 1;
}

.medium-zoom-overlay {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  opacity: 0;
  transition: opacity 300ms;
  will-change: opacity;
}
.theme--light .medium-zoom-overlay {
  background: #fff;
}
.theme--dark .medium-zoom-overlay {
  background: #152028;
}

.medium-zoom--opened .medium-zoom-overlay {
  cursor: pointer;
  cursor: zoom-out;
  opacity: 1;
}

.medium-zoom-image {
  cursor: pointer;
  cursor: zoom-in;
  transition: transform 300ms cubic-bezier(0.2, 0, 0.2, 1) !important;
  z-index: 100;
}

.medium-zoom-image--hidden {
  visibility: hidden;
}

.medium-zoom-image--opened {
  position: relative;
  cursor: pointer;
  cursor: zoom-out;
  will-change: transform;
}

.newsletter {
  scroll-margin-top: 75px;
}
.newsletter:has(.sib-form-block__img) {
  scroll-margin-top: 170px;
}
.newsletter:has(+ .contact-form) .sib-form #sib-form .sib-form-block__img {
  display: none;
}
.newsletter .sib-form {
  text-align: center;
  background-color: transparent;
  padding: 0 20px;
  margin: 30px 0;
}
.newsletter .sib-form #error-message {
  font-size: 16px;
  text-align: left;
  color: #661d1d;
  background-color: #ffeded;
  border-radius: 3px;
  border-color: #ff4949;
  max-width: 540px;
}
.newsletter .sib-form #success-message {
  font-size: 16px;
  text-align: left;
  color: #085229;
  background-color: #e7faf0;
  border-radius: 3px;
  border-color: #13ce66;
  max-width: 540px;
}
.newsletter .sib-form #sib-container {
  text-align: center;
  background-color: transparent;
  max-width: 540px;
  border-radius: 4px;
  border-width: 1px;
  border-color: #c0ccd9;
  border-style: solid;
  direction: ltr;
}
.theme--light .newsletter .sib-form #sib-container {
  box-shadow: 0 8px 16px rgba(10, 10, 10, 0.1);
}
.theme--dark .newsletter .sib-form #sib-container {
  box-shadow: 0 8px 16px rgba(0, 0, 0, 0.4);
}
.newsletter .sib-form #sib-container a {
  text-decoration: underline;
  color: #2bb2fc;
}
.newsletter .sib-form #sib-form .sib-form-block {
  padding: 8px 16px;
  position: relative;
  text-align: left;
  background-color: transparent;
}
.newsletter .sib-form #sib-form .sib-form-block.title {
  text-align: center;
}
.newsletter .sib-form #sib-form .sib-form-block.title h2 {
  font-size: 3.2rem;
  font-weight: 400;
  margin-top: 8px;
  margin-bottom: 0;
}
@media screen and (max-width: 480px) {
  .newsletter .sib-form #sib-form .sib-form-block.title h2 {
    font-size: 2.8rem;
  }
}
.newsletter .sib-form #sib-form .sib-form-block.subtitle {
  text-align: center;
  font-size: 16px;
}
.newsletter .sib-form #sib-form .sib-form-block__img {
  position: absolute;
  top: -85px;
  right: -85px;
  display: block;
  margin: 16px auto;
  width: 150px;
  height: 150px;
  border-radius: 75px;
  border: 1px solid #c0ccd9;
  backdrop-filter: blur(20px);
}
.theme--light .newsletter .sib-form #sib-form .sib-form-block .sib-text-form-block {
  color: #9f9f9f;
}
.theme--dark .newsletter .sib-form #sib-form .sib-form-block .sib-text-form-block {
  color: #9f9f9f;
}
.newsletter .sib-form #sib-form .sib-form-block .clickable__icon {
  vertical-align: middle;
}
.newsletter .sib-form #sib-form .sib-form-block .svgIcon-sphere {
  width: 63px;
  height: 63px;
}
.newsletter .sib-form #sib-form .sib-form-block input[type^=checkbox],
.newsletter .sib-form #sib-form .sib-form-block textarea,
.newsletter .sib-form #sib-form .sib-form-block input:first-child,
.newsletter .sib-form #sib-form .sib-form-block input:last-child {
  padding: 0.5rem 0.75rem;
  outline: none;
  background: transparent;
  height: auto;
}
.theme--light .newsletter .sib-form #sib-form .sib-form-block input[type^=checkbox],
.theme--light .newsletter .sib-form #sib-form .sib-form-block textarea,
.theme--light .newsletter .sib-form #sib-form .sib-form-block input:first-child,
.theme--light .newsletter .sib-form #sib-form .sib-form-block input:last-child {
  color: #464646;
}
.theme--dark .newsletter .sib-form #sib-form .sib-form-block input[type^=checkbox],
.theme--dark .newsletter .sib-form #sib-form .sib-form-block textarea,
.theme--dark .newsletter .sib-form #sib-form .sib-form-block input:first-child,
.theme--dark .newsletter .sib-form #sib-form .sib-form-block input:last-child {
  color: #eeeeee;
}
.newsletter .sib-form #sib-form .sib-form-block input[type^=checkbox]::placeholder, .newsletter .sib-form #sib-form .sib-form-block input[type^=checkbox]:-ms-input-placeholder, .newsletter .sib-form #sib-form .sib-form-block input[type^=checkbox]::-ms-input-placeholder, .newsletter .sib-form #sib-form .sib-form-block input[type^=checkbox]::-webkit-input-placeholder, .newsletter .sib-form #sib-form .sib-form-block input[type^=checkbox]::-moz-placeholder, .newsletter .sib-form #sib-form .sib-form-block input[type^=checkbox]:-moz-placeholder,
.newsletter .sib-form #sib-form .sib-form-block textarea::placeholder,
.newsletter .sib-form #sib-form .sib-form-block textarea:-ms-input-placeholder,
.newsletter .sib-form #sib-form .sib-form-block textarea::-ms-input-placeholder,
.newsletter .sib-form #sib-form .sib-form-block textarea::-webkit-input-placeholder,
.newsletter .sib-form #sib-form .sib-form-block textarea::-moz-placeholder,
.newsletter .sib-form #sib-form .sib-form-block textarea:-moz-placeholder,
.newsletter .sib-form #sib-form .sib-form-block input:first-child::placeholder,
.newsletter .sib-form #sib-form .sib-form-block input:first-child:-ms-input-placeholder,
.newsletter .sib-form #sib-form .sib-form-block input:first-child::-ms-input-placeholder,
.newsletter .sib-form #sib-form .sib-form-block input:first-child::-webkit-input-placeholder,
.newsletter .sib-form #sib-form .sib-form-block input:first-child::-moz-placeholder,
.newsletter .sib-form #sib-form .sib-form-block input:first-child:-moz-placeholder,
.newsletter .sib-form #sib-form .sib-form-block input:last-child::placeholder,
.newsletter .sib-form #sib-form .sib-form-block input:last-child:-ms-input-placeholder,
.newsletter .sib-form #sib-form .sib-form-block input:last-child::-ms-input-placeholder,
.newsletter .sib-form #sib-form .sib-form-block input:last-child::-webkit-input-placeholder,
.newsletter .sib-form #sib-form .sib-form-block input:last-child::-moz-placeholder,
.newsletter .sib-form #sib-form .sib-form-block input:last-child:-moz-placeholder {
  text-align: left;
}
.newsletter .sib-form #sib-form .entry__field {
  background: transparent;
}
.theme--light .newsletter .sib-form #sib-form .entry__field {
  border: 1px solid #eeeeee;
}
.theme--dark .newsletter .sib-form #sib-form .entry__field {
  border: 1px solid #464646;
}
.newsletter .sib-form #sib-form .entry__label {
  font-weight: 600;
  text-align: left;
  font-size: 16px;
  margin-bottom: 8px;
}
.newsletter .sib-form #sib-form .entry__error {
  padding: 10px;
  line-height: 1.2em;
  font-size: 16px;
  text-align: left;
  color: #661d1d;
  background-color: #ffeded;
  border-radius: 3px;
  border-color: #ff4949;
}
.newsletter .sib-form #sib-form .entry__specification {
  font-size: 12px;
  text-align: left;
  margin-top: 4px;
}
.newsletter .sib-form #sib-form .checkbox__label {
  font-size: 14px;
  text-align: left;
  background-color: transparent;
}
.newsletter .sib-form #sib-form > div:nth-of-type(4) > .sib-form-block {
  text-align: left;
}
.newsletter .sib-form #sib-form .sib-form-block__button {
  font-size: 16px;
  text-align: center;
  font-weight: 700;
  text-transform: uppercase;
  color: #ffffff;
  background-color: #3e4857;
  border-radius: 3px;
  border-width: 0px;
  width: 100%;
  margin-bottom: 8px;
}
.newsletter .sib-form #sib-form .sib-form-block__button.is-disabled {
  opacity: 0.5;
  cursor: not-allowed;
}
.newsletter .sib-form #sib-form .sib-optin,
.newsletter .sib-form #sib-form .sib-form__declaration {
  transition: max-height 0.5s ease, padding 0.5s ease, margin 0.5s ease;
  max-height: 0;
  overflow: hidden;
  padding: 0 16px;
}
.newsletter .sib-form #sib-form .is-visible {
  max-height: 500px; /* Adjust as needed to fit content */
  padding: 8px 16px;
}
.newsletter .sib-form #sib-form .sib-form__declaration {
  font-size: 14px;
  text-align: left;
  background-color: transparent;
}
.theme--light .newsletter .sib-form #sib-form .sib-form__declaration {
  color: #9f9f9f;
}
.theme--dark .newsletter .sib-form #sib-form .sib-form__declaration {
  color: #9f9f9f;
}

.post__content .newsletter .sib-form {
  padding: 0;
  margin: 60px 0;
}

.post__content .newsletter:not(:has(+ .contact-form)) .sib-form:has(img),
.post + .newsletter:not(:has(+ .contact-form)) .sib-form:has(img) {
  margin-top: 96px;
}

@media screen and (max-width: 480px) {
  .sib-form #sib-container {
    padding: 16px 9px;
  }
  .newsletter .sib-form #sib-form .sib-form-block.title {
    font-size: 28px;
  }
  .post__content .sib-form {
    margin: 30px 0;
  }
}
@media (max-width: 1135px) {
  .newsletter:not(:has(+ .contact-form)) .sib-form:has(img) {
    margin-top: 106px;
  }
  .post__content .newsletter:not(:has(+ .contact-form)) .sib-form:has(img),
  .post + .newsletter:not(:has(+ .contact-form)) .sib-form:has(img) {
    margin-top: 146px;
  }
  .newsletter .sib-form #sib-form .sib-form-block img {
    top: -135px;
    left: unset;
    right: unset;
    position: relative;
    margin-bottom: -125px;
  }
}
/* (CONTACT) FORM */
.contact-form {
  margin-top: 30px;
}

.form-style {
  width: 100%;
}

.form-style ul {
  padding: 0;
  margin: 0;
  list-style: none;
}

.form-style ul li {
  display: block;
  margin-bottom: 10px;
  min-height: 35px;
}
.theme--light .form-style ul li {
  background-color: #fff;
  color: #464646;
}
.theme--dark .form-style ul li {
  background-color: #152028;
  color: #eeeeee;
}

.form-style ul li .field-style {
  box-sizing: border-box;
  -webkit-box-sizing: border-box;
  -moz-box-sizing: border-box;
  padding: 8px;
  outline: none;
  font-family: inherit;
  font-size: 16px;
}
.theme--light .form-style ul li .field-style {
  border: 1px solid #eeeeee;
  background-color: #fff;
  color: #464646;
}
.theme--dark .form-style ul li .field-style {
  border: 1px solid #384249;
  background-color: #152028;
  color: #eeeeee;
}

.form-style ul li .field-style:focus {
  box-shadow: 0 0 5px;
  border: 1px solid;
}

.form-style ul li .field-split {
  width: 49%;
}

.form-style ul li .field-full {
  width: 100%;
}

.form-style ul li input.align-left {
  float: left;
}

.form-style ul li input.align-right {
  float: right;
}

.form-style ul li textarea {
  width: 100%;
  height: auto;
}

.form-style ul li input[type=button],
.form-style ul li input[type=submit] {
  display: inline-block;
  cursor: pointer;
  text-decoration: none;
  width: 100%;
}

.form-style input[name=_gotcha] {
  display: none;
}

/* (CONTACT) FORM END */
#TableOfContents {
  display: block;
  background: transparent;
}

#TableOfContents ul {
  list-style: none;
  line-height: 1.9em;
  margin: 0;
}

#TableOfContents > ul {
  padding-left: 0;
}

#TableOfContents li a {
  display: inherit;
  color: #6086b4;
}

#TableOfContents li a:hover {
  display: inherit;
}

table {
  display: table;
  border-collapse: collapse;
}

tr {
  display: table-row;
}
.theme--light tr:first-child th {
  background: rgba(163, 201, 249, 0.4);
}
.theme--dark tr:first-child th {
  background: rgba(58, 83, 121, 0.4);
}
.theme--light tr:nth-child(even) td {
  background: rgba(10, 10, 10, 0.05);
}
.theme--dark tr:nth-child(even) td {
  background: rgba(0, 0, 0, 0.25);
}

th,
td {
  display: table-cell;
  padding: 8px;
}
.theme--light th,
.theme--light td {
  border-top: 1px solid #eeeeee;
  border-bottom: 1px solid #eeeeee;
}
.theme--dark th,
.theme--dark td {
  border-top: 1px solid #384249;
  border-bottom: 1px solid #384249;
}