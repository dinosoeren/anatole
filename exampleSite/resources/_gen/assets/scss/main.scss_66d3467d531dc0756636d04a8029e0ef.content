}
.pagination__list-item a.page-link:focus {
  box-shadow: none;
}
.pagination__list-item a.page-link:has(.icon) {
  padding: 5px 3px 4px 3px;
}
.pagination__list-item a.page-link .icon {
  position: relative;
  top: 2px;
}

.navbar-trigger {
  cursor: pointer;
  height: 3.25rem;
  position: relative;
