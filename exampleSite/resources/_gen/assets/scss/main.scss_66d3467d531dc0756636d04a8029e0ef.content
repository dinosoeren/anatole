.alert {
  display: flex;
  gap: 0.75rem;
  align-items: center;
  padding: 1rem 1rem 0.9rem 1rem;
  border-style: solid;
  border-radius: 4px;
  border-width: 1px;
  margin-top: 1rem;
  line-height: 1.4em;
}
