.footer {
  text-align: center;
  margin: 0 auto;
  bottom: 0;
  width: 100%;
  padding-bottom: 20px;
  flex: 0;
  position: relative;
}
.footer__list {
  list-style: none;
  padding: 0;
  display: flex;
  justify-content: center;
}
.footer__item {
  font-size: 1.4rem;
}
.footer__item:not(:first-of-type)::before {
  content: "·";
  padding: 4px;
}
