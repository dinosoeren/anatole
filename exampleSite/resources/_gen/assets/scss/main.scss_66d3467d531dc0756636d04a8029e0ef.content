  color: #fff;
  background-color: #ffc107;
}
.theme--dark .alert__indicator {
  color: #152028;
  background-color: #ffc107;
}

/* Fade in transition used to hide content shift from applied filter on render */
@keyframes fadeIn {
  0% {
    opacity: 0;
  }
  100% {
    opacity: 1;
  }
}
