.theme--light .post {
  background-color: #fff;
}
.theme--dark .post {
  background-color: #152028;
}
.post__meta {
  display: flex;
  flex-wrap: wrap;
  list-style: none;
  padding: 0;
  gap: 1em;
}
.post__content .post__meta {
  line-height: 1.1em;
}
.post__meta-item {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 0.4em;
}
.post__meta-icon {
  position: relative;
  top: -2px;
}
.post__meta-text:not(:last-child) {
  margin-right: 4px;
}
.post__thumbnail {
  width: 100%;
  height: 25em;
  object-fit: cover;
  display: block;
  transition: opacity 0.2s ease;
}
@media screen and (max-width: 480px) {
  .post__thumbnail {
    height: 15em;
  }
}
.post__thumbnail.hd-loading {
  opacity: 0.98;
}
.post__thumbnail-wrapper {
  border-radius: 4px;
  width: 100%;
  margin-bottom: 1em;
  overflow: hidden;
  transition: box-shadow 0.3s ease;
  position: relative;
}
.theme--light .post__thumbnail-wrapper {
  box-shadow: 0 8px 16px rgba(10, 10, 10, 0.1);
}
.theme--dark .post__thumbnail-wrapper {
  box-shadow: 0 8px 16px rgba(0, 0, 0, 0.4);
}
.post__thumbnail-overlay {
  position: absolute;
  cursor: default;
  pointer-events: none;
  bottom: 0;
  display: flex;
  justify-content: space-between;
  width: 100%;
  padding-top: 20px;
  font-weight: 600;
}
.theme--light .post__thumbnail-overlay {
  background: linear-gradient(0, rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0));
}
.theme--dark .post__thumbnail-overlay {
  background: linear-gradient(0, rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0));
}
@media screen and (max-width: 480px) {
  .post__thumbnail-overlay {
    flex-direction: column-reverse;
    height: 100%;
  }
  .theme--light .post__thumbnail-overlay {
    background: linear-gradient(0, rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0), rgba(0, 0, 0, 0), rgba(0, 0, 0, 0));
  }
  .theme--dark .post__thumbnail-overlay {
    background: linear-gradient(0, rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0), rgba(0, 0, 0, 0), rgba(0, 0, 0, 0));
  }
}
.post__thumbnail-overlay-icon {
  position: relative;
  top: 2px;
}
.post__thumbnail-overlay-icon + span {
  margin-left: 1px;
}
.post__thumbnail-overlay a {
  pointer-events: all;
}
.post__thumbnail-overlay .left,
.post__thumbnail-overlay .right,
.post__thumbnail-overlay .middle {
  display: flex;
  align-content: end;
  flex-wrap: wrap;
  flex-shrink: 1;
  width: calc(100% - 10px);
}
.post__thumbnail-overlay .left {
  gap: 5px;
  padding: 6px 8px;
  text-wrap: nowrap;
  color: #eee;
}
.post__thumbnail-overlay .left a {
  color: #eee;
}
.theme--light .post__thumbnail-overlay .left a:hover {
  color: #6086b4;
}
.theme--dark .post__thumbnail-overlay .left a:hover {
  color: #6086b4;
}
.post__thumbnail-overlay .right {
  text-align: right;
  justify-content: end;
  padding: 5px;
  flex-shrink: 1;
  text-wrap: nowrap;
  width: auto;
}
.post__thumbnail-overlay .right .category {
  font-size: 1.2rem;
  margin: 3px;
  text-wrap: nowrap;
}
.post__thumbnail-overlay .middle {
  flex: 1;
  pointer-events: none;
}
.post__content {
  /* Prevent ios font scaling issue */
  /* Youtube Video Embed Styles */
}
