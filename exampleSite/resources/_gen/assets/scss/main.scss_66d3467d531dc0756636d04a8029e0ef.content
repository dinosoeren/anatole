.pagination {
  margin: 30px;
  padding: 0px 0 56px 0;
  text-align: center;
}
.pagination__list {
  list-style: none;
  margin: 0;
  padding: 0;
  height: 13px;
}
.pagination__list-item {
  margin: 0 4px;
  display: inline;
  line-height: 1;
  text-decoration: none;
}
.theme--light .pagination__list-item {
  color: #464646;
}
.theme--dark .pagination__list-item {
  color: #eeeeee;
}
.pagination__list-item a.page-link {
  padding: 5px 6px 4px 6px;
  border-radius: 4px;
  transition: box-shadow 0.2s ease;
}
.theme--light .pagination__list-item a.page-link {
