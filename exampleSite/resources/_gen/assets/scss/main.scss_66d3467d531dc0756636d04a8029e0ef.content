}
.alert__indicator {
  display: block;
  flex-shrink: 0;
  border-radius: 9999px;
  padding: 0.5rem;
  width: 1.7rem;
  height: 1.7rem;
  text-align: center;
  font-weight: 800;
  line-height: 1.2em;
}
