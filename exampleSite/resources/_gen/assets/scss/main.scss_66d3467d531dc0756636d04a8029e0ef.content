}
.theme--dark .post__content h4 a {
  color: #eeeeee;
}
.post__content ul,
.post__content ol {
  line-height: 1.9em;
  font-weight: 400;
  word-wrap: break-word;
}
.post__content img {
  display: block;
  margin-left: auto;
  margin-right: auto;
  max-width: 100%;
  object-fit: contain;
  transition: opacity 0.2s ease;
  position: relative;
}
.post__content img[data-hd-src].hd-loading {
  filter: brightness(0.98);
}
@media screen and (max-width: 480px) {
  .post__content img {
    max-width: calc(100% + 60px);
    width: calc(100% + 60px);
    height: auto;
    left: -30px;
  }
}
.post__content img.inline {
  display: inline-block;
  max-width: 100%;
  width: revert-layer;
  left: 0;
}
.post__content-icon {
  position: relative;
  top: 2px;
}
@media screen and (max-width: 480px) {
  .post__content blockquote {
    padding: 1px 30px 1px 11px;
    position: relative;
    left: -30px;
    width: calc(100% + 14px);
  }
}
.post__content blockquote img {
  margin-bottom: 1em;
}
@media screen and (max-width: 480px) {
  .post__content blockquote img {
    max-width: calc(100% - 2.2em);
    left: unset;
    margin-left: 2.2em;
  }
}
.post__content blockquote a {
  padding: 2px 0;
}
.theme--light .post__content blockquote a {
  color: #000;
  border-bottom: 2px solid #464646;
}
.theme--dark .post__content blockquote a {
  color: #fff;
  border-bottom: 2px solid #eeeeee;
}
.post__content blockquote a:hover {
  border-color: transparent;
}
.post__content figure {
  max-width: 100%;
  height: auto;
  margin: 0 auto;
  text-align: center;
  /** Avoid stretching imgs with fixed height */
}
.post__content figure.inline {
  display: inline-block;
}
.post__content figure.inline img {
  max-width: 100%;
  width: revert-layer;
  left: 0;
}
.post__content figure.big {
  max-width: 87.5%;
}
.post__content figure.medium {
  max-width: 75%;
}
.post__content figure.small {
  max-width: 50%;
}
.post__content figure.tiny {
  max-width: 25%;
}
@media screen and (min-width: 961px) {
  .post__content figure.right {
    max-width: 50%;
    float: right;
    margin: 0 0 0 1.5em;
  }
}
@media screen and (min-width: 961px) {
  .post__content figure.left {
    max-width: 50%;
    float: left;
    margin-right: 1.5em;
  }
}
.post__content figure img {
  max-height: fit-content;
}
.post__footer {
  padding: 0 0 12px 0;
}
