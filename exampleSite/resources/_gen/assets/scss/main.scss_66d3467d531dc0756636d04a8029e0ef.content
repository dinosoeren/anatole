}
.theme--dark .archive__heading {
  color: #eeeeee;
}
.archive__list {
  padding: 0;
  line-height: 1.125em !important;
}
.archive__list-item {
  display: flex;
  justify-content: space-between;
  padding-bottom: 5px;
  list-style-type: none;
  align-items: center;
}
.archive__list-icon {
