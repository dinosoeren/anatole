  background-color: #fff;
  position: relative;
  overflow: hidden;
  left: -30px;
  width: 100svw;
  /* Fade in to hide content shift from applied filter */
  animation: 1s ease-in-out 0s 1 fadeIn;
}
.portfolio__image-wrapper--right, .portfolio__image-wrapper--left {
  margin-right: auto;
  margin-left: auto;
  max-width: inherit;
}
.theme--light .portfolio__image-wrapper--right, .theme--light .portfolio__image-wrapper--left {
  background-color: #fff;
}
.theme--dark .portfolio__image-wrapper--right, .theme--dark .portfolio__image-wrapper--left {
  background-color: #152028;
}
@media screen and (min-width: 961px) {
  .portfolio__image-wrapper--right, .portfolio__image-wrapper--left {
    left: 0;
    width: 60%;
    object-fit: contain;
    max-width: none;
    border-radius: 0.5em;
    padding: 0;
  }
  .theme--light .portfolio__image-wrapper--right, .theme--light .portfolio__image-wrapper--left {
    border: 1px solid #eeeeee;
  }
  .theme--dark .portfolio__image-wrapper--right, .theme--dark .portfolio__image-wrapper--left {
    border: 1px solid #464646;
  }
}
@media screen and (min-width: 961px) {
  .portfolio__image-wrapper--left {
    margin-right: auto;
    margin-left: 0;
  }
}
@media screen and (min-width: 961px) {
  .portfolio__image-wrapper--right {
    margin-right: 0;
    margin-left: auto;
  }
}
.portfolio__image-wrapper + .portfolio__details {
  margin-top: -30px;
}
@media screen and (min-width: 961px) {
  .portfolio__image-wrapper + .portfolio__details {
    margin-top: -48px;
  }
}
.portfolio__details {
  padding: 32px;
  position: relative;
  border-radius: 0.5em;
}
.theme--light .portfolio__details {
  border: 1px solid #eeeeee;
  background: rgba(10, 10, 10, 0);
  box-shadow: 0 5px 10px rgba(10, 10, 10, 0.05);
}
.theme--dark .portfolio__details {
  border: 1px solid #384249;
  background: rgba(0, 0, 0, 0.2);
  box-shadow: 0 5px 10px rgba(0, 0, 0, 0.25);
}
@media screen and (min-width: 961px) {
  .portfolio__details {
    padding: 48px;
  }
}
.portfolio__details--left, .portfolio__details--right {
  padding-top: 16px;
  backdrop-filter: blur(20px);
}
.theme--light .portfolio__details--left, .theme--light .portfolio__details--right {
  border-bottom: 1px solid #eeeeee;
}
.theme--dark .portfolio__details--left, .theme--dark .portfolio__details--right {
  border-bottom: 1px solid #384249;
}
@media screen and (min-width: 961px) {
  .portfolio__details--left, .portfolio__details--right {
    padding-top: 32px;
    border-bottom: 0px;
    width: 60%;
  }
}
@media screen and (min-width: 961px) {
  .portfolio__details--right {
    margin-left: auto;
  }
}
.portfolio__details .separator {
  /* Fade in to hide content shift from applied filter */
  animation: 1s ease-in-out 0s 1 fadeIn;
}
.portfolio__details .tag {
  cursor: pointer;
}
.portfolio__meta {
  display: flex;
  flex-wrap: wrap;
  list-style: none;
  padding: 0;
  row-gap: 0.8rem;
  /* Fade in to hide content shift from applied filter */
  animation: 1s ease-in-out 0s 1 fadeIn;
}
.theme--light .portfolio__meta {
  color: #9f9f9f;
}
.theme--dark .portfolio__meta {
  color: #9f9f9f;
}
.portfolio__meta-item:not(:last-child) {
  margin-right: 1.25rem;
}
.portfolio__button {
  font-weight: 400;
  display: inline-block;
  position: relative;
  outline: 0;
  text-align: center;
  text-decoration: none;
  cursor: pointer;
  white-space: nowrap;
  font-style: normal;
  border-radius: 999em;
  padding: 10px 15px;
}
.theme--light .portfolio__button {
  background: #fff;
  color: #6086b4;
  border: 1px solid #eeeeee;
}
.theme--dark .portfolio__button {
  background: #152028;
  color: #6086b4;
  border: 1px solid #464646;
}
.portfolio__button:hover {
  display: inline-block;
  position: relative;
  outline: 0px;
  background: transparent;
  text-align: center;
  text-decoration: none;
  cursor: pointer;
  white-space: nowrap;
  font-weight: 400;
  font-style: normal;
  border-radius: 999em;
}
.portfolio__button-wrapper {
  padding-bottom: 1em;
  /* Fade in to hide content shift from applied filter */
  animation: 1s ease-in-out 0s 1 fadeIn;
}

.hidden {
  display: none !important;
}

.portfolio-filter-tags {
  display: flex;
  align-items: stretch;
  position: sticky;
  z-index: 1;
  padding: 10px 30px;
  width: calc(100% - 60px);
  backdrop-filter: blur(5px);
}
.theme--light .portfolio-filter-tags {
  background: rgba(255, 255, 255, 0.7);
}
.theme--dark .portfolio-filter-tags {
  background: rgba(21, 32, 40, 0.7);
}
.navpos--top .portfolio-filter-tags {
  top: calc(3.25rem + 12px);
}
@media screen and (min-width: 961px) {
  .navpos--top .portfolio-filter-tags {
    top: calc(1.8rem + 49px);
  }
}
.navpos--bottom .portfolio-filter-tags {
  top: 0;
}
@media screen and (min-width: 961px) {
  .navpos--bottom .portfolio-filter-tags {
    top: calc(1.8rem + 49px);
  }
}
@supports (-webkit-touch-callout: none) {
  .navpos--top .portfolio-filter-tags {
    top: calc(3.25rem + 12px);
  }
  @media screen and (min-width: 961px) {
    .navpos--top .portfolio-filter-tags {
      top: calc(1.8rem + 49px);
    }
  }
  .navpos--bottom .portfolio-filter-tags {
    top: calc(3.25rem + 12px);
  }
  @media screen and (min-width: 961px) {
    .navpos--bottom .portfolio-filter-tags {
      top: calc(1.8rem + 49px);
    }
  }
}
.portfolio-filter-tags .multi-select-container {
  position: relative;
  flex: 1;
}
.portfolio-filter-tags .input-container {
  display: flex;
  flex-wrap: wrap;
  width: calc(100% - 10px);
  padding: 5px;
  border-radius: 0.25rem 0 0 0.25rem;
  border: 0;
}
.theme--light .portfolio-filter-tags .input-container {
  background: rgba(70, 70, 70, 0.1);
}
.theme--dark .portfolio-filter-tags .input-container {
  background: rgba(238, 238, 238, 0.1);
}
.theme--light .portfolio-filter-tags .input-container:has(input:focus) {
  background: rgba(96, 134, 180, 0.3);
}
.theme--dark .portfolio-filter-tags .input-container:has(input:focus) {
  background: rgba(96, 134, 180, 0.3);
}
.portfolio-filter-tags #tag-input {
  outline: none;
  border: none;
  background: none;
  flex: 1;
  width: 40%;
  min-width: 90px;
  max-width: 110px;
  padding: calc(0.25rem + 1px);
  font-size: 16px;
}
.theme--light .portfolio-filter-tags #tag-input {
  color: #464646;
}
.theme--dark .portfolio-filter-tags #tag-input {
  color: #eeeeee;
}
.theme--light .portfolio-filter-tags #tag-input::placeholder {
  color: rgba(70, 70, 70, 0.5);
}
.theme--dark .portfolio-filter-tags #tag-input::placeholder {
  color: rgba(238, 238, 238, 0.5);
}
.portfolio-filter-tags .selected-tags {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  font-size: 0.8em;
}
.portfolio-filter-tags .selected-tags:not(:has(> :first-child)) {
  display: none;
}
.portfolio-filter-tags .selected-tag {
  padding: 0.25rem 0.5rem;
  border-radius: 0.25rem;
  display: flex;
  align-items: center;
  gap: 0.25rem;
}
.theme--light .portfolio-filter-tags .selected-tag {
  background: #fff;
  border: 1px solid #eeeeee;
}
.theme--dark .portfolio-filter-tags .selected-tag {
  background: #152028;
  border: 1px solid #384249;
}
.portfolio-filter-tags .remove-tag {
  cursor: pointer;
  font-weight: bold;
}
.portfolio-filter-tags .dropdown {
  position: absolute;
  width: 100%;
  border-top: none;
  max-height: 150px;
  overflow-y: auto;
  z-index: 1000;
  font-size: 0.9em;
}
.theme--light .portfolio-filter-tags .dropdown {
  background: #fff;
  border: 1px solid #eeeeee;
}
.theme--dark .portfolio-filter-tags .dropdown {
  background: #152028;
  border: 1px solid #384249;
}
.portfolio-filter-tags .dropdown-option {
  padding: 0.5rem;
  cursor: pointer;
}
.theme--light .portfolio-filter-tags .dropdown-option:hover, .theme--light .portfolio-filter-tags .dropdown-option.focused {
  color: #fff;
  background: #6086b4;
}
.theme--dark .portfolio-filter-tags .dropdown-option:hover, .theme--dark .portfolio-filter-tags .dropdown-option.focused {
  color: #152028;
  background: #6086b4;
}
.portfolio-filter-tags .dropdown-option span {
  font-family: monospace;
  font-size: 0.8em;
  opacity: 0.8;
  margin-left: 0.3em;
}
.portfolio-filter-tags .portfolio-filter-clear {
  padding: 5px 10px;
  border-radius: 0 0.25rem 0.25rem 0;
  cursor: pointer;
  background: none;
  border: 0;
}
.theme--light .portfolio-filter-tags .portfolio-filter-clear {
  color: #464646;
  background: rgba(70, 70, 70, 0.1);
}
.theme--dark .portfolio-filter-tags .portfolio-filter-clear {
  color: #eeeeee;
  background: rgba(238, 238, 238, 0.1);
}
.portfolio-filter-tags .portfolio-filter-clear[disabled] {
  border-color: transparent;
  cursor: not-allowed;
}
.theme--light .portfolio-filter-tags .portfolio-filter-clear[disabled] {
  color: rgba(70, 70, 70, 0.5);
}
.theme--dark .portfolio-filter-tags .portfolio-filter-clear[disabled] {
  color: rgba(238, 238, 238, 0.5);
}
.theme--light .portfolio-filter-tags .portfolio-filter-clear:focus {
  border-color: #6086b4;
}
.theme--dark .portfolio-filter-tags .portfolio-filter-clear:focus {
  border-color: #6086b4;
}

