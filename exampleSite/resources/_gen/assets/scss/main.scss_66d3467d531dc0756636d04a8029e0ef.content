.optionswitch {
  position: relative;
}
.optionswitch__label {
  cursor: pointer;
  white-space: nowrap;
  display: flex;
  align-items: start;
  justify-content: center;
  padding: 16px 0;
}
@media screen and (min-width: 961px) {
  .optionswitch__label {
    padding: 0;
  }
}
@media screen and (min-width: 961px) {
  .optionswitch__label.nav__link--active {
    padding-bottom: 24px;
    margin-bottom: -24px;
  }
}
.optionswitch__label .icon {
  margin-left: 2px;
  top: 0;
}
.optionswitch__list {
  display: none;
  list-style: none;
  padding: 0;
  position: relative;
}
@media screen and (min-width: 961px) {
  .optionswitch__list {
    border-radius: 5px;
    position: absolute;
    top: 32px;
    backdrop-filter: blur(5px);
  }
  .theme--light .optionswitch__list {
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 8px 16px rgba(10, 10, 10, 0.1);
  }
  .theme--dark .optionswitch__list {
    background: rgba(21, 32, 40, 0.95);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.4);
  }
}
.optionswitch__list-item {
  background: transparent;
  display: block;
  line-height: 1;
  bottom: 0;
  text-align: center;
  white-space: nowrap;
}
.theme--light .optionswitch__list-item {
  color: #464646;
}
.theme--dark .optionswitch__list-item {
  color: #eeeeee;
}
@media screen and (min-width: 961px) {
  .optionswitch__list-item {
    padding: 12px;
    text-align: left;
  }
}
.optionswitch__link {
  display: flex;
  justify-content: center;
  width: 100%;
  padding: 16px 0;
}
@media screen and (min-width: 961px) {
  .optionswitch__link {
    padding: 0;
  }
}
.optionswitch__triangle {
  display: none;
}
.optionswitch__triangle::before {
  content: "";
  border-radius: 2px 0px 0px 0px;
  height: 14px;
  left: 25%;
  overflow: hidden;
  position: absolute;
  transform: rotate(45deg) translateY(0px) translatex(10px);
  width: 14px;
}
.theme--light .optionswitch__triangle::before {
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 0 10px rgba(10, 10, 10, 0.2);
  border-color: rgba(255, 255, 255, 0.95);
}
.theme--dark .optionswitch__triangle::before {
  background: rgba(21, 32, 40, 0.95);
  box-shadow: 0 0 10px rgba(0, 0, 0, 0.4);
  border-color: rgba(21, 32, 40, 0.95);
}
.optionswitch__picker:checked ~ .optionswitch__list {
  display: block;
}
@media screen and (min-width: 961px) {
  .optionswitch__picker:checked ~ .optionswitch__triangle {
    display: block;
  }
}

