/** see https://developer.mozilla.org/en-US/docs/Web/HTML/Reference/Elements/Heading_Elements#specifying_a_uniform_font_size_for_h1 */
:where(h1) {
  margin-block: 0.67em;
  font-size: 2em;
}

a {
  text-decoration: none;
}
.theme--light a {
  color: #464646;
}
.theme--dark a {
  color: #eeeeee;
}
.theme--light a:hover {
  color: #6086b4;
}
.theme--dark a:hover {
  color: #6086b4;
}

blockquote {
  margin-left: 0;
  margin-right: 0;
  padding: 0.1em 1em;
}
.theme--light blockquote {
  background: oklch(from #eeeeee calc(l - 0.1) calc(c - 0.05) h/0.2);
  border-left: 5px solid #6086b4;
}
.theme--dark blockquote {
  background: oklch(from #464646 calc(l - 0.1) calc(c - 0.05) h/0.2);
  border-left: 5px solid #6086b4;
}
blockquote p:first-of-type {
  font-size: 1.2em;
  font-weight: bold;
  margin-left: 0.5em;
}
blockquote p:nth-of-type(2) {
  margin-top: -1em;
}
blockquote p:not(:first-of-type) {
  margin-left: 2.2em;
}
blockquote svg {
  position: relative;
  top: 5px;
  left: -3px;
  height: 1.2em;
  width: 1.2em;
}
.theme--light blockquote.success {
  background: oklch(from #51d88a calc(l - 0.1) calc(c - 0.05) h/0.2);
  border-color: #51d88a;
}
.theme--light blockquote.success svg {
  color: #51d88a;
}
.theme--dark blockquote.success {
  background: oklch(from #51d88a calc(l - 0.1) calc(c - 0.05) h/0.2);
  border-color: #51d88a;
}
.theme--dark blockquote.success svg {
  color: #51d88a;
}
.theme--light blockquote.failure {
  background: oklch(from #ef5753 calc(l - 0.1) calc(c - 0.05) h/0.2);
  border-color: #ef5753;
}
.theme--light blockquote.failure svg {
  color: #ef5753;
}
.theme--dark blockquote.failure {
  background: oklch(from #ef5753 calc(l - 0.1) calc(c - 0.05) h/0.2);
  border-color: #ef5753;
}
.theme--dark blockquote.failure svg {
  color: #ef5753;
}
.theme--light blockquote.warning {
  background: oklch(from #ffc107 calc(l - 0.1) calc(c - 0.05) h/0.2);
  border-color: #ffc107;
}
.theme--light blockquote.warning svg {
  color: #ffc107;
}
.theme--dark blockquote.warning {
  background: oklch(from #ffc107 calc(l - 0.1) calc(c - 0.05) h/0.2);
  border-color: #ffc107;
}
.theme--dark blockquote.warning svg {
  color: #ffc107;
}
.theme--light blockquote.disclaimer {
  background: oklch(from #a4a4a4 calc(l - 0.1) calc(c - 0.05) h/0.2);
  border-color: #a4a4a4;
}
.theme--light blockquote.disclaimer svg {
  color: #a4a4a4;
}
.theme--dark blockquote.disclaimer {
  background: oklch(from #a4a4a4 calc(l - 0.1) calc(c - 0.05) h/0.2);
  border-color: #a4a4a4;
}
.theme--dark blockquote.disclaimer svg {
  color: #a4a4a4;
}
.theme--light blockquote.tip {
  background: oklch(from #ffee8c calc(l - 0.1) calc(c - 0.05) h/0.2);
  border-color: #ffee8c;
}
.theme--light blockquote.tip svg {
  color: color-mix(in hsl, #464646 20%, #ffee8c);
}
.theme--dark .theme--light blockquote.tip svg {
  color: #ffee8c;
}
.theme--dark blockquote.tip {
  background: oklch(from #ffee8c calc(l - 0.1) calc(c - 0.05) h/0.2);
  border-color: #ffee8c;
}
.theme--dark blockquote.tip svg {
  color: color-mix(in hsl, #eeeeee 20%, #ffee8c);
}
.theme--dark .theme--dark blockquote.tip svg {
  color: #ffee8c;
}
.theme--light blockquote.question {
  background: oklch(from #ffba8c calc(l - 0.1) calc(c - 0.05) h/0.2);
  border-color: #ffba8c;
}
.theme--light blockquote.question svg {
  color: #ffba8c;
}
.theme--dark blockquote.question {
  background: oklch(from #ffba8c calc(l - 0.1) calc(c - 0.05) h/0.2);
  border-color: #ffba8c;
}
.theme--dark blockquote.question svg {
  color: #ffba8c;
}

p {
  line-height: 1.9em;
}

* {
  font-family: inherit;
}

body {
  font-family: "PingHei", "PingFang SC", "Helvetica Neue", "Work Sans", "Hiragino Sans GB", sans-serif;
  font-size: 1.6rem;
}

.html {
  -webkit-font-smoothing: antialiased;
  font-size: 62.5%;
}

.body {
  width: 100%;
  margin: 0 auto;
}
.theme--light .body {
  color: #464646;
  background-color: #fff;
}
.theme--dark .body {
  color: #eeeeee;
  background-color: #152028;
}

.header {
  backdrop-filter: blur(20px);
  width: 100%;
  z-index: 10;
}
.theme--light .header {
  background-color: rgba(255, 255, 255, 0.7);
  box-shadow: 0 0 5px rgba(10, 10, 10, 0.2);
}
.theme--dark .header {
  background-color: rgba(21, 32, 40, 0.7);
  box-shadow: 0 0 5px rgba(0, 0, 0, 0.4);
}
@media screen and (max-width: 960px) {
  .navpos--top .header {
    position: fixed;
    top: 0;
    bottom: auto;
  }
  .navpos--bottom .header {
    position: fixed;
    top: auto;
    bottom: 0;
  }
  @supports (-webkit-touch-callout: none) {
    .navpos--top .header {
      position: fixed;
      top: 0;
      bottom: auto;
    }
    .navpos--bottom .header {
      position: fixed;
      top: 0;
      bottom: auto;
    }
  }
}
@media screen and (min-width: 961px) {
  .header {
    position: sticky;
    top: 0;
  }
  .theme--light .header {
    box-shadow: 5px 0 5px rgba(10, 10, 10, 0.2);
  }
  .theme--dark .header {
    box-shadow: 5px 0 5px rgba(0, 0, 0, 0.4);
  }
}
@media print {
  .header {
    display: none;
  }
}
.header-trigger-wrapper {
  display: flex;
  justify-content: space-between;
}
@media screen and (min-width: 961px) {
  .header-trigger-wrapper {
    display: none;
  }
}

.nav {
  display: none;
}
@media screen and (min-width: 961px) {
  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: none;
  }
}
.nav--active, .header:not(.nav-loaded) .nav:hover, .header:not(.nav-loaded):has(.navbar-burger:hover) .nav {
  display: block;
}
@media screen and (max-width: 960px) {
  .navpos--top .nav--above {
    display: none !important;
  }
  @supports (-webkit-touch-callout: none) {
    .nav--above {
      display: none !important;
    }
  }
}
@media screen and (min-width: 961px) {
  .nav--above {
    display: none !important;
  }
}
@media screen and (max-width: 960px) {
  .navpos--bottom .nav--below {
    display: none !important;
  }
}
.nav__list {
  margin: 0;
  list-style: none;
  padding: 0;
  width: 100%;
}
.nav__list--end {
  display: flex;
}
@media screen and (min-width: 961px) {
  .nav__list {
    display: flex;
    padding: 24px 30px;
    gap: 20px;
  }
  .nav__list--end {
    flex-shrink: 1;
    justify-content: flex-end;
  }
}
.nav__list-item {
  text-transform: uppercase;
  text-align: center;
  white-space: nowrap;
}
@media screen and (min-width: 961px) {
  .nav__list-item {
    padding-top: 0;
    padding-bottom: 0;
  }
  .nav__list-item:has(.navpos-switch) {
    display: none;
  }
}
@supports (-webkit-touch-callout: none) {
  .nav__list-item:has(.navpos-switch) {
    display: none;
  }
}
@media screen and (max-width: 960px) {
  .nav__list-item:has(.themeswitch), .nav__list-item:has(.navpos-switch) {
    flex: 1;
  }
}
.nav__list-item .icon {
  position: relative;
  top: 2px;
}
.nav__link {
  display: flex;
  justify-content: center;
  width: 100%;
  padding: 16px 0;
}
@media screen and (min-width: 961px) {
  .nav__link {
    padding: 0;
  }
}
@media screen and (min-width: 961px) {
  .nav__link--active {
    padding-bottom: 24px;
    margin-bottom: -24px;
  }
  .theme--light .nav__link--active {
    border-bottom: 1px solid #464646;
  }
  .theme--dark .nav__link--active {
    border-bottom: 1px solid #eeeeee;
  }
}

.offline {
  display: flex;
  min-height: 100vh;
  width: 100%;
  text-align: center;
  justify-content: center;
  align-items: center;
  flex-direction: column;
  margin: 0 0 1em 0;
  padding: 0;
}
.offline-image {
  opacity: 0.5;
  transition: opacity 200ms;
}
.offline-image:hover {
  opacity: 1;
}
.theme--light .offline-icon, .theme--light .offline-title {
  color: #464646;
}
.theme--dark .offline-icon, .theme--dark .offline-title {
  color: #eeeeee;
}
.offline-info {
  padding: 0 2em;
  margin-bottom: 2em;
}
.theme--light .offline-info {
  color: #9f9f9f;
}
.theme--dark .offline-info {
  color: #9f9f9f;
}
.offline-actions {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
}
.offline-action {
  display: flex;
  flex-wrap: nowrap;
  gap: 0.5rem;
  align-items: center;
  text-decoration: none;
  margin: 0.25rem;
  padding: 1rem 1rem 0.75rem 1rem;
}
.theme--light .offline-action {
  background: #a3c9f9;
  color: #464646;
}
.theme--dark .offline-action {
  background: #3a5379;
  color: #eeeeee;
}
.theme--light .offline-action-go-back {
  background: #b8e2d3;
}
.theme--dark .offline-action-go-back {
  background: #3d6656;
}
.theme--light .offline-action-try-again {
  background: #f9d1d1;
}
.theme--dark .offline-action-try-again {
  background: #7a4c58;
}
.theme--light .offline-action-cta {
  background: #ffe5b4;
}
.theme--dark .offline-action-cta {
  background: #7a6240;
}
.offline-action-icon {
  vertical-align: middle;
  position: relative;
  top: -1px;
}

.toc-wrapper {
  display: none !important;
  margin-top: 1rem;
  padding-top: 0.75rem;
}
@media screen and (min-width: 961px) {
  .toc-wrapper {
    display: block !important;
    margin: 1.5em 1em 0.5em 1em;
    padding-top: 1rem;
  }
  .toc-wrapper.center {
    text-align: center;
  }
}
.toc-wrapper .table-of-contents, .toc-wrapper-mobile .table-of-contents {
  line-height: 1.4;
}
.toc-wrapper .table-of-contents::-webkit-scrollbar, .toc-wrapper-mobile .table-of-contents::-webkit-scrollbar {
  display: none;
  width: 4px;
}
.toc-wrapper .table-of-contents::-webkit-scrollbar-track, .toc-wrapper-mobile .table-of-contents::-webkit-scrollbar-track {
  border-radius: 2px;
}
.theme--light .toc-wrapper .table-of-contents::-webkit-scrollbar-track, .theme--light .toc-wrapper-mobile .table-of-contents::-webkit-scrollbar-track {
  background: #eeeeee;
}
.theme--dark .toc-wrapper .table-of-contents::-webkit-scrollbar-track, .theme--dark .toc-wrapper-mobile .table-of-contents::-webkit-scrollbar-track {
  background: #464646;
}
.toc-wrapper .table-of-contents::-webkit-scrollbar-thumb, .toc-wrapper-mobile .table-of-contents::-webkit-scrollbar-thumb {
  border-radius: 2px;
}
.theme--light .toc-wrapper .table-of-contents::-webkit-scrollbar-thumb, .theme--light .toc-wrapper-mobile .table-of-contents::-webkit-scrollbar-thumb {
  background: #6086b4;
}
.theme--light .toc-wrapper .table-of-contents::-webkit-scrollbar-thumb:hover, .theme--light .toc-wrapper-mobile .table-of-contents::-webkit-scrollbar-thumb:hover {
  background: #fff;
}
.theme--dark .toc-wrapper .table-of-contents::-webkit-scrollbar-thumb, .theme--dark .toc-wrapper-mobile .table-of-contents::-webkit-scrollbar-thumb {
  background: #6086b4;
}
.theme--dark .toc-wrapper .table-of-contents::-webkit-scrollbar-thumb:hover, .theme--dark .toc-wrapper-mobile .table-of-contents::-webkit-scrollbar-thumb:hover {
  background: #152028;
}
.toc-wrapper .table-of-contents ul, .toc-wrapper-mobile .table-of-contents ul {
  list-style: none;
  margin: 0;
  padding: 0;
}
.toc-wrapper .table-of-contents ul ul, .toc-wrapper-mobile .table-of-contents ul ul {
  position: relative;
  margin-left: 0.5rem;
}
@media screen and (min-width: 961px) {
  .toc-wrapper .table-of-contents ul ul, .toc-wrapper-mobile .table-of-contents ul ul {
    margin-left: 0;
  }
}
.toc-wrapper .table-of-contents li, .toc-wrapper-mobile .table-of-contents li {
  margin: 0;
}
.toc-wrapper .table-of-contents a, .toc-wrapper-mobile .table-of-contents a {
  display: block;
  text-decoration: none;
  line-height: 1.1em;
  transition: all 0.2s ease;
  position: relative;
}
.theme--light .toc-wrapper .table-of-contents a, .theme--light .toc-wrapper-mobile .table-of-contents a {
  color: #464646;
}
.theme--light .toc-wrapper .table-of-contents a:hover, .theme--light .toc-wrapper-mobile .table-of-contents a:hover {
  background-color: rgba(238, 238, 238, 0.5);
}
.theme--light .toc-wrapper .table-of-contents a.toc-active, .theme--light .toc-wrapper-mobile .table-of-contents a.toc-active {
  background-color: rgba(255, 255, 255, 0.5);
  border-left: 3px solid #6086b4;
  font-weight: 500;
  color: #6086b4;
}
.theme--dark .toc-wrapper .table-of-contents a, .theme--dark .toc-wrapper-mobile .table-of-contents a {
  color: #eeeeee;
}
.theme--dark .toc-wrapper .table-of-contents a:hover, .theme--dark .toc-wrapper-mobile .table-of-contents a:hover {
  background-color: rgba(70, 70, 70, 0.5);
}
.theme--dark .toc-wrapper .table-of-contents a.toc-active, .theme--dark .toc-wrapper-mobile .table-of-contents a.toc-active {
  background-color: rgba(21, 32, 40, 0.5);
  border-left: 3px solid #6086b4;
  font-weight: 500;
  color: #6086b4;
}
.toc-wrapper .table-of-contents ul ul a, .toc-wrapper-mobile .table-of-contents ul ul a {
  font-size: 0.8em;
  text-transform: uppercase;
}
.theme--light .toc-wrapper .table-of-contents ul ul a.toc-active, .theme--light .toc-wrapper-mobile .table-of-contents ul ul a.toc-active {
  background-color: rgba(255, 255, 255, 0.5);
}
.theme--dark .toc-wrapper .table-of-contents ul ul a.toc-active, .theme--dark .toc-wrapper-mobile .table-of-contents ul ul a.toc-active {
  background-color: rgba(21, 32, 40, 0.5);
}
.toc-wrapper-mobile {
  display: none;
  top: 44px;
  left: 0;
  width: calc(100svw - 2rem);
  max-height: 40svh;
  padding: 1rem;
  overflow-y: auto;
}
.expanded .toc-wrapper-mobile, .header:not(.toc-loaded) .toc-wrapper-mobile:hover, .header:not(.toc-loaded):has(.toc-trigger-mobile:hover) .toc-wrapper-mobile {
  display: block;
}
.navpos--bottom .toc-wrapper-mobile.toc--below {
  display: none !important;
}
.navpos--top .toc-wrapper-mobile.toc--above {
  display: none !important;
}
@supports (-webkit-touch-callout: none) {
  .toc-wrapper-mobile.toc--above {
    display: none !important;
  }
}
.toc-wrapper-mobile:has(+ .nav--active) {
  display: none !important;
}
@media screen and (min-width: 961px) {
  .toc-wrapper-mobile {
    display: none !important;
  }
}
.toc-wrapper-mobile .table-of-contents::-webkit-scrollbar {
  width: 4px;
}
.toc-wrapper-mobile .table-of-contents a {
  padding: 1rem 0.75rem;
}
.toc-wrapper-mobile .table-of-contents ul ul a {
  padding: 0.5rem 0.5rem 0.5rem 1.5rem;
}
.toc-wrapper .table-of-contents {
  max-height: 20svh;
  overflow-y: auto;
}
.toc-wrapper .table-of-contents::-webkit-scrollbar {
  display: none;
}
.toc-wrapper .table-of-contents a {
  padding: 0.3rem 0.75rem;
  margin: 0 0.25rem;
  overflow: hidden;
}
@media screen and (min-width: 961px) {
  .toc-wrapper .table-of-contents a {
    padding: 0.875rem 1rem;
    margin: 0;
  }
}
.toc-wrapper .table-of-contents ul ul a {
  padding: 0.2rem 0.5rem;
}
@media screen and (min-width: 961px) {
  .toc-wrapper .table-of-contents ul ul a {
    padding: 0.75rem 1.5rem;
  }
}

.toc-title {
  font-weight: 400;
  text-align: center;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 0 0.75rem;
  margin-bottom: 0.5rem;
}
.theme--light .toc-title {
  color: #9f9f9f;
}
.theme--dark .toc-title {
  color: #9f9f9f;
}
@media screen and (min-width: 961px) {
  .toc-title {
    padding: 0 1rem;
    margin-bottom: 0.75rem;
  }
}
.toc-title-mobile {
  font-weight: 400;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 1rem;
  padding-bottom: 0.5rem;
}
.theme--light .toc-title-mobile {
  border-bottom: 1px solid rgba(238, 238, 238, 0.5);
}
.theme--dark .toc-title-mobile {
  border-bottom: 1px solid rgba(70, 70, 70, 0.5);
}

.toc-trigger-mobile {
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  margin-left: 0;
}
@media screen and (min-width: 961px) {
  .toc-trigger-mobile {
    display: none;
  }
}
.toc-trigger-mobile[disabled] {
  opacity: 0;
  cursor: default;
}
.toc-trigger-mobile i {
  font-size: 1.5rem;
}

@media screen and (min-width: 961px) {
  .toc-container-mobile {
    display: none !important;
  }
}

.animated {
  transition: top 0.8s linear;
  animation-duration: 1s;
  -webkit-animation-duration: 1s;
  -moz-animation-duration: 1s;
  -ms-animation-duration: 1s;
  -o-animation-duration: 1s;
  -webkit-animation-name: fadeInDown;
  -moz-animation-name: fadeInDown;
  -o-animation-name: fadeInDown;
  animation-name: fadeInDown;
}
@media screen and (min-width: 961px) {
  .animated.no-desktop-animated {
    transition: none;
    animation-duration: 0s;
    -webkit-animation-duration: 0s;
    -moz-animation-duration: 0s;
    -ms-animation-duration: 0s;
    -o-animation-duration: 0s;
  }
}
@-webkit-keyframes fadeInDown {
  0% {
    -webkit-transform: translateY(-20px);
  }
  100% {
    -webkit-transform: translateY(0);
  }
}
@-moz-keyframes fadeInDown {
  0% {
    -moz-transform: translateY(-20px);
  }
  100% {
    -moz-transform: translateY(0);
  }
}
@-o-keyframes fadeInDown {
  0% {
    -o-transform: translateY(-20px);
  }
  100% {
    -o-transform: translateY(0);
  }
}
@keyframes fadeInDown {
  0% {
    transform: translateY(-20px);
  }
  100% {
    transform: translateY(0);
  }
}

.category {
  padding: 4px 6px;
  border-radius: 2px;
  display: inline-block;
  font-size: 1.4rem;
  backdrop-filter: blur(5px);
  margin: 5px 8px 5px 0;
}
.theme--light .category {
  border: 1px solid #eeeeee;
  background-color: rgba(226.1, 226.1, 226.1, 0.55);
  color: #464646 !important;
}
.theme--dark .category {
  border: 1px solid #384249;
  background-color: rgba(66.5, 66.5, 66.5, 0.55);
  color: #eeeeee !important;
}
.theme--light .category:hover {
  border: 1px solid #9f9f9f;
}
.theme--dark .category:hover {
  border: 1px solid #9f9f9f;
}

.tag {
  display: inline-block;
  font-size: 1.4rem;
  margin: 5px 8px 5px 0;
}
.theme--light .tag {
  color: #9f9f9f;
}
.theme--dark .tag {
  color: #9f9f9f;
}
.tag::before {
  content: "#";
}

.wrapper {
  display: flex;
  flex-direction: column;
}
@media screen and (min-width: 961px) {
  .wrapper {
    flex-direction: row;
  }
}
@media screen and (min-width: 1921px) {
  .wrapper {
    justify-content: center;
  }
}
.wrapper__main {
  width: 100%;
}
@media screen and (min-width: 961px) {
  .wrapper__main {
    width: 60%;
  }
}
@media screen and (min-width: 1921px) {
  .wrapper__main {
    width: 48%;
  }
}
.wrapper__main--fullscreen {
  margin-top: 20px;
}
@media screen and (min-width: 961px) {
  .wrapper__main--fullscreen {
    width: 100%;
    margin-top: 0px;
  }
}
@media screen and (min-width: 1921px) {
  .wrapper__main--fullscreen {
    width: 1920px;
  }
}
.wrapper__sidebar {
  width: 100%;
  padding: 16px 0;
}
@media screen and (min-width: 961px) {
  .wrapper__sidebar {
    width: 40%;
    padding: 0;
  }
}
@media screen and (min-width: 1921px) {
  .wrapper__sidebar {
    width: 32%;
  }
}
.wrapper__sidebar--hidden {
