.search {
  display: flex;
  flex-direction: column;
  margin: 1.5em 30px 0 30px;
  position: relative;
}
@media screen and (max-width: 960px) {
  .search {
    margin: 5px;
    flex: 1;
  }
}
.search label {
  display: flex;
  align-items: center;
  margin: auto;
  padding: 6px 6px 6px 9px;
  border-radius: 24px;
  min-width: 16px;
  position: relative;
}
.theme--light .search label {
  background: #e2d5f7;
}
@media screen and (max-width: 960px) {
  .theme--light .search label {
    background: none;
  }
}
.theme--dark .search label {
  background: #5a4c7a;
}
@media screen and (max-width: 960px) {
  .theme--dark .search label {
    background: none;
  }
}
@media screen and (max-width: 960px) {
  .search label {
    padding: 0;
  }
}
.search label::after {
  content: "Search";
  padding: 0 0.7rem;
  font-weight: 400;
  font-size: 0.9em;
  font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, "Open Sans", "Helvetica Neue", sans-serif;
}
@media screen and (max-width: 960px) {
  .search label::after {
    content: "";
    padding: 0;
  }
}
.search label > .hi-svg-inline {
  flex-shrink: 0;
  transition: left 100ms;
}
@media screen and (max-width: 960px) {
  .search label > .hi-svg-inline {
    position: absolute;
    left: 0;
  }
}
.search:hover label, .search.active label, .search label:has(+ input[type=search]:focus), .search.no-expand label {
  padding: 6px;
  margin-right: 0.5rem;
}
@media screen and (max-width: 960px) {
  .search:hover label, .search.active label, .search label:has(+ input[type=search]:focus), .search.no-expand label {
    padding: 0;
    margin: 0;
    min-width: 0;
  }
}
.search:hover label::after, .search.active label::after, .search label:has(+ input[type=search]:focus)::after, .search.no-expand label::after {
  content: "";
  padding: 0;
}
@media screen and (max-width: 960px) {
  .search:hover label > .hi-svg-inline, .search.active label > .hi-svg-inline, .search label:has(+ input[type=search]:focus) > .hi-svg-inline, .search.no-expand label > .hi-svg-inline {
    left: 9px;
  }
}
.search:hover input[type=search], .search.active input[type=search],
.search input[type=search]:focus, .search.no-expand input[type=search] {
  width: 100%;
  opacity: 1;
  padding: 0.1em 0.5em 0 0.5em;
}
@media screen and (max-width: 960px) {
  .search:hover input[type=search], .search.active input[type=search],
  .search input[type=search]:focus, .search.no-expand input[type=search] {
    padding-left: calc(1em + 15px);
  }
}
.search__no-results {
  text-align: center;
  padding: 1rem;
  font-size: 0.9em;
}
.theme--light .search__no-results {
  color: #9f9f9f;
}
.theme--dark .search__no-results {
  color: #9f9f9f;
}
@media screen and (min-width: 961px) {
  .search__no-results {
    text-align: left;
  }
}
.searchbox {
  display: flex;
  width: 100%;
  position: relative;
  justify-content: center;
}
.search input[type=search] {
  opacity: 0;
  border-radius: 0.2rem;
  outline: none;
  line-height: 2em;
  width: 0;
  padding: 0.1em 0 0 0;
  overflow-x: hidden;
  transition: width 200ms;
  font-size: 16px;
}
.theme--light .search input[type=search] {
  border: 1px solid #9f9f9f;
  background: #fff;
  caret-color: #464646;
  color: #464646;
}
.theme--dark .search input[type=search] {
  border: 1px solid #9f9f9f;
  background: #152028;
  caret-color: #eeeeee;
  color: #eeeeee;
}
.theme--light .search input[type=search]:focus {
  border: 1px solid #9f9f9f;
}
.theme--dark .search input[type=search]:focus {
  border: 1px solid #9f9f9f;
}
.theme--light .search input[type=search]::placeholder {
  color: #9f9f9f;
}
.theme--dark .search input[type=search]::placeholder {
  color: #9f9f9f;
}
.search input[type=search]::-webkit-search-cancel-button {
  appearance: none;
}
.search__suggestions {
  display: flex;
  flex-direction: column;
  border-radius: 0.3rem;
}
@media screen and (min-width: 961px) {
  .search__suggestions {
    left: 3rem;
    top: 4rem;
    position: absolute;
    width: calc(100% - 3rem);
    z-index: 1000;
    backdrop-filter: blur(5px);
  }
  .theme--light .search__suggestions {
    background: rgba(255, 255, 255, 0.7);
    box-shadow: 0 0.5rem 1rem rgba(10, 10, 10, 0.2);
    border: 1px solid #eeeeee;
  }
  .theme--dark .search__suggestions {
    background: rgba(21, 32, 40, 0.7);
    box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.4);
    border: 1px solid #464646;
  }
}
.search__suggestions--hidden {
  display: none;
}
.search__suggestions:hover, .sidebar .search:not(.active) .searchbox:has(input[type=search]:focus) + .search__suggestions, .header:not(.expanded):has(.search:not(.active)):has(input[type=search]:focus) .search__suggestions {
  display: flex;
}
.navpos--bottom .search__suggestions--below {
  display: none !important;
}
.navpos--top .search__suggestions--above {
  display: none !important;
}
@supports (-webkit-touch-callout: none) {
  .search__suggestions--above {
    display: none !important;
  }
}
.search__suggestions:has(.search__suggestions-item) {
  padding: 0 0 0.5rem 0;
}
.search__suggestions-item {
  display: flex;
  align-items: center;
  padding: 0.75rem 1rem;
  gap: 1rem;
}
.theme--light .search__suggestions-item:not(:last-child) {
  border-bottom: 0 dashed #eeeeee;
}
.theme--dark .search__suggestions-item:not(:last-child) {
  border-bottom: 0 dashed #464646;
}
.search__suggestions-item:focus, .search__suggestions-item:focus-visible, .search__suggestions-item:hover {
  cursor: pointer;
  outline: none;
}
.theme--light .search__suggestions-item:focus, .theme--light .search__suggestions-item:focus-visible, .theme--light .search__suggestions-item:hover {
  background: rgba(238, 238, 238, 0.4);
}
.theme--dark .search__suggestions-item:focus, .theme--dark .search__suggestions-item:focus-visible, .theme--dark .search__suggestions-item:hover {
  background: rgba(70, 70, 70, 0.4);
}
.search__suggestions-item img,
.search__suggestions-item picture {
  width: 40px;
  height: 40px;
  flex-shrink: 0;
}
@media screen and (min-width: 961px) {
  .search__suggestions-item img,
  .search__suggestions-item picture {
    width: 30px;
    height: 30px;
  }
}
@media screen and (min-width: 1210px) {
  .search__suggestions-item img,
  .search__suggestions-item picture {
    width: 40px;
    height: 40px;
  }
}
.search__suggestions-item img {
  object-fit: cover;
  border-radius: 4px;
}
.search__suggestions-title {
  font-weight: 500;
}
.theme--light .search__suggestions-title span {
  color: #9f9f9f;
}
.theme--dark .search__suggestions-title span {
  color: #9f9f9f;
}
.search__suggestions-title span:last-of-type {
  font-size: 0.75em;
}
@media screen and (min-width: 961px) {
  .search__suggestions-title {
    font-size: 1.3rem;
  }
}
@media screen and (min-width: 1210px) {
  .search__suggestions-title {
    font-size: 1.6rem;
  }
}

.sidebar .search {
  display: none;
}
@media screen and (min-width: 961px) {
  .sidebar .search {
    display: flex;
  }
}
@media screen and (max-width: 960px) {
